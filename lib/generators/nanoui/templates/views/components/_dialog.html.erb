<%# NanoUI Dialog (native <dialog> with Stimulus)
  Options: size (sm, md, lg, full), title, description, title_id (auto), class
  Yields: :trigger, default (body), :footer
  Usage:
    render "components/dialog", title: "Edit Profile", description: "Update your info." do |f|
      content_for(:trigger) do
        render "components/button" do "Open" end
      end
      content_for(:footer) do
        '<button class="button button--outline" data-action="nanoui-dialog#close">Cancel</button>'.html_safe
      end
      "Dialog body content here"
    end
%>
<%
  size      = local_assigns.fetch(:size, "md")
  title     = local_assigns.fetch(:title, "")
  desc      = local_assigns.fetch(:description, nil)
  title_id  = local_assigns.fetch(:title_id, "dialog-title-#{SecureRandom.hex(4)}")
  classes   = local_assigns.fetch(:class, "")

  css = ["dialog"]
  css << "dialog--#{size}" unless size == "md"
  css << classes if classes.present?
%>

<div data-controller="nanoui-dialog">
  <%= yield :trigger if content_for?(:trigger) %>

  <dialog data-nanoui-dialog-target="modal"
          data-action="click->nanoui-dialog#clickBackdrop cancel->nanoui-dialog#cancel"
          class="<%= css.join(" ").strip %>"
          aria-labelledby="<%= title_id %>">
    <div class="dialog__content">
      <header class="dialog__header">
        <h2 id="<%= title_id %>" class="dialog__title"><%= title %></h2>
        <% if desc %>
          <p class="dialog__description"><%= desc %></p>
        <% end %>
      </header>

      <div class="dialog__body">
        <%= yield %>
      </div>

      <% if content_for?(:footer) %>
        <footer class="dialog__footer">
          <%= yield :footer %>
        </footer>
      <% end %>

      <button data-action="nanoui-dialog#close" class="dialog__close"
              type="button" aria-label="Close dialog">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </dialog>
</div>
